{
  "version": 2,
  "builds": [
    {
      "src": "staffing-and-recruitment-agency/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/staffing-and-recruitment-agency/$1"
    }
  ]
}
